<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<style>
  .coffee-grid { display:grid; grid-template-columns: 1.5fr 1fr; gap:16px; }
  #map { height: 620px; border-radius: 12px; border:1px solid var(--border); }
  .toolbox { display:grid; gap:12px; }
  .card { border:1px solid var(--border); border-radius: 12px; padding:12px; }
  .search-row { display:grid; grid-template-columns: 1fr 140px auto; gap:8px; }
  .input, .select { width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:10px; }
  .cafe-list { max-height: 300px; overflow:auto; display:grid; gap:8px; margin-top:10px; }
  .cafe-item { border:1px solid #e5e7eb; border-radius:10px; padding:10px; cursor:pointer; }
  .cafe-item:hover { background:#f9fafb; }
  .meta { font-size:12px; color:#6b7280; }
  .form-grid { display:grid; gap:8px; }
  @media (max-width: 1100px){ .coffee-grid { grid-template-columns: 1fr; } #map { height:420px; } }
</style>

<div class="coffee-grid">
  <div id="map"></div>

  <div class="toolbox">
    <div class="card">
      <h3>카페 찾기</h3>
      <div class="search-row">
        <input id="keyword" class="input" placeholder="카페명/메뉴 검색" />
             <input id="cafeSearchKeyword" ... />   <!-- 카페명/메뉴 검색 input -->
        <select id="cafeSearchDistrict" ...>...</select>  <!-- 지역구 select -->
        <button id="cafeSearchBtn" type="button">검색</button>
      </div>
      <div id="cafeList" class="cafe-list"></div>
    </div>
    
    <div id="cafeSearchResults"></div>
    
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
  const map = L.map('map').setView([37.5665, 126.9780], 12);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);

  let markers = [];

  const renderList = (items) => {
    const list = document.getElementById('cafeList');
    list.innerHTML = items.map((cafe) => `
      <div class="cafe-item" data-id="${cafe.id}">
        <strong>${cafe.name}</strong>
        <div class="meta">${cafe.district} · ${cafe.signature}</div>
        <div class="meta">${cafe.address}</div>
      </div>
    `).join('');

    document.querySelectorAll('.cafe-item').forEach((el) => {
      el.addEventListener('click', () => {
        const cafe = items.find((item) => item.id === Number(el.dataset.id));
        if (!cafe) return;
        map.flyTo([cafe.lat, cafe.lng], 15);
      });
    });
  };

  const renderMarkers = (items) => {
    markers.forEach((marker) => map.removeLayer(marker));
    markers = items.map((cafe) => {
      const marker = L.marker([cafe.lat, cafe.lng]).addTo(map);
      marker.bindPopup(`<b>${cafe.name}</b><br/>${cafe.address}<br/>⭐ ${cafe.rating}`);
      return marker;
    });
  };

  const loadCafes = async () => {
    const keyword = document.getElementById('keyword').value;
    const district = document.getElementById('district').value;

    const params = new URLSearchParams({ keyword, district });
    const res = await fetch(`/api/cafes?${params.toString()}`);
    const data = await res.json();

    renderList(data.items);
    renderMarkers(data.items);
  };

  document.getElementById('searchBtn').addEventListener('click', loadCafes);

  document.getElementById('cafeForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const payload = Object.fromEntries(formData.entries());

    const res = await fetch('/api/cafes', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (!res.ok) {
      alert('입력값을 확인해주세요.');
      return;
    }

    e.target.reset();
    await loadCafes();
  });

  loadCafes();
</script>
