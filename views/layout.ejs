<!DOCTYPE html>
<html lang="ko">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= (typeof title !=='undefined' ? title : "커피맵" ) %>
  </title>
  <link rel="stylesheet"
    href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <div class="app">
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-logo">☕</div>
        <div>
          <div class="brand-title">커피맵</div>
          <div style="font-size:12px; color:var(--muted);">Seoul Cafe Guide</div>
        </div>
      </div>

      <div>
        <div class="nav-title">Explore</div>
        <nav class="nav">
          <a href="/" class="<%= (typeof active !== 'undefined' && active === 'home') ? 'active' : '' %>">홈</a>
        </nav>
      </div>
    </aside>

    <main class="main">
      <div class="topbar">
        <div>
          <h1 class="page-title">
            <%= (typeof headerTitle !=='undefined' ? headerTitle : "커피맵" ) %>
          </h1>
          <% if (typeof headerSub !=='undefined' && headerSub) { %>
            <p class="page-sub">
              <%= headerSub %>
            </p>
            <% } %>
        </div>

        <% if (typeof headerAction !=='undefined' && headerAction) { %>
          <div><%- headerAction %></div>
          <% } %>
      </div>

      <div class="panel">
        <%- body %>
      </div>
    </main>
  </div>
</body>

</html>
